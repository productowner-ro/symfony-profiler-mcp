{
    "name": "productowner-ro/symfony-profiler-mcp",
    "description": "Symfony bundle that exposes profiler data via MCP protocol to AI-powered IDEs. Built on symfony/mcp-bundle.",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "ProductOwner.ro",
            "homepage": "https://productowner.ro"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/framework-bundle": "^7.3|^8.0",
        "symfony/http-kernel": "^7.3|^8.0",
        "symfony/mcp-bundle": "^0.6",
        "symfony/finder": "^7.3|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "ProductOwner\\SymfonyProfilerMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ProductOwner\\SymfonyProfilerMcp\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "phpstan": "vendor/bin/phpstan analyse -l 6",
        "cs-fix": "vendor/bin/php-cs-fixer fix",
        "cs-check": "vendor/bin/php-cs-fixer fix --dry-run --diff"
    },
    "config": {
        "sort-packages": true
    }
}
